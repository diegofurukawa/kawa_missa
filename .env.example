# ===================================================
# .env.example — Referência de variáveis obrigatórias
# NUNCA commitar o .env real. Este arquivo é seguro.
# ===================================================

# ===== PORTS =====
FRONTEND_PORT=3115

# ===== NETWORK =====
DOCKER_NETWORK_NAME=kawatech-network
APP_IPV4=172.27.0.55
MIGRATE_IPV4=172.27.0.56

# ===== DATABASE (EXTERNAL POSTGRESQL) =====
DB_HOST=kawa_postgres
DB_PORT=5432
DB_NAME=db_kawamissa
DB_USER=postgres
DB_PASSWORD=
DB_SCHEMA=public
DB_SSL=false

DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=${DB_SCHEMA}

# ===== NODE / NEXT =====
NODE_ENV=production
HOST=0.0.0.0
HOSTNAME=0.0.0.0
EXTERNAL_HOST=0.0.0.0

# ===== AUTHENTICATION =====
AUTH_SECRET=
NEXTAUTH_SECRET=
# NEXTAUTH_URL=  # Deixar comentado; AUTH_TRUST_HOST=true cobre o runtime
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===== APPLICATION URLS =====
NEXT_PUBLIC_HIDE_NEXTJS_DEV_TOOLS=true
NEXT_PUBLIC_CEP_API_URL=https://postalcode.furukawatech.com.br/api/PostalCode
NEXT_PUBLIC_APP_URL=https://${EXTERNAL_HOST}
NEXT_PUBLIC_API_URL=https://${EXTERNAL_HOST}/api
NEXT_PUBLIC_BASE_URL=https://${EXTERNAL_HOST}
NEXT_PUBLIC_DEFAULT_HOSTS=https://${EXTERNAL_HOST}